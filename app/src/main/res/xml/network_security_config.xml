<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration for Jellyfin Android client.

    Cleartext (HTTP) traffic is intentionally permitted globally via the NSC base-config.
    This is the correct, supported way to allow HTTP on Android — NOT android:usesCleartextTraffic
    in the manifest (which is deprecated at API 37 and should not be used).

    Why HTTP must be allowed:
    - Many users run Jellyfin on their home network without TLS (e.g. http://192.168.1.x:8096).
    - Android NSC domain-config does not support IP address ranges/CIDR notation, so a
      blanket base-config is the only practical way to cover arbitrary local server addresses.
    - HTTPS is strongly encouraged via the app's UI, and Certificate Transparency (enforced
      at API 37+) applies automatically to all HTTPS connections.

    Future hardening path: if/when the app gains a "known servers" store, add <domain-config>
    entries per saved server with cleartextTrafficPermitted="false" to lock them to HTTPS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
            <!-- User-installed certs (e.g. self-signed CA) are trusted — required for the
                 TOFU certificate-pinning flow in JellyfinAuthRepository. -->
            <certificates src="user"/>
        </trust-anchors>
    </base-config>

    <debug-overrides>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>
</network-security-config>
